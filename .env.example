# ============================================================
#  Cafezal CRM — environment reference
#  This is a combined reference. The app reads TWO separate files:
#    • server/.env   (backend — copy from server/.env.example)
#    • client/.env   (frontend — copy from client/.env.example)
# ============================================================

# ---------- server/.env ----------
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

ADMIN_EMAILS=admin@cafezal.com

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cafezal CRM <crm@cafezal.com>

CRON_ENABLED=true
CRON_SCHEDULE=0 9 * * *
CRON_TIMEZONE=Europe/Rome
REMINDER_DAYS_AHEAD=3
CRON_SECRET=change-me-to-a-long-random-string

SEED_USER_PASSWORD=Cafezal2026!
SEED_ADMIN_EMAIL=admin@cafezal.com

# ---------- client/.env ----------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_API_BASE_URL=http://localhost:4000
VITE_ADMIN_EMAILS=
