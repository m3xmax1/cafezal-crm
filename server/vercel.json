{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [{ "src": "api/index.js", "use": "@vercel/node" }],
  "routes": [{ "src": "/(.*)", "dest": "api/index.js" }],
  "crons": [
    {
      "path": "/api/cron/daily-reminder",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/cron/cassa-sync?days=2",
      "schedule": "0 3 * * *"
    }
  ]
}
