# ---------- Server ----------
PORT=4000
NODE_ENV=development

# Allowed browser origin(s) for CORS (comma-separated, or * for any)
CLIENT_ORIGIN=http://localhost:5173

# ---------- Supabase ----------
# Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---------- Roles ----------
# Comma-separated admin emails (see ALL opportunities). Optional.
ADMIN_EMAILS=admin@cafezal.com

# ---------- Email (SMTP for nodemailer) ----------
# Leave SMTP_HOST empty in dev to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cafezal CRM <crm@cafezal.com>

# ---------- Reminder scheduler ----------
CRON_ENABLED=true
# Standard 5-field cron. Default: every day at 09:00.
CRON_SCHEDULE=0 9 * * *
# IANA timezone — Europe/Rome handles UTC+1/UTC+2 (DST) automatically.
CRON_TIMEZONE=Europe/Rome
# Days ahead to consider an opportunity "in scadenza".
REMINDER_DAYS_AHEAD=3
# Shared secret to protect POST/GET /api/cron/daily-reminder (recommended).
CRON_SECRET=change-me-to-a-long-random-string

# ---------- Seed script (optional) ----------
SEED_USER_PASSWORD=Cafezal2026!
SEED_ADMIN_EMAIL=admin@cafezal.com
